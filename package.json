{
  "name": "research-proj",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "node backend/server.cjs",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "test": "jest",
    "test:shortages": "jest backend/shortages.test.cjs --runInBand",
    "test:shortages:parity": "node scripts/test-shortages-parity.mjs",
    "sync:shortages": "node scripts/sync-shortages-catalogs.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@imexs/audit-trail": "^1.0.3",
    "@mui/icons-material": "^6.0.0",
    "@mui/material": "^6.0.0",
    "@mui/x-charts": "^7.23.2",
    "@mui/x-data-grid": "^8.22.0",
    "@supabase/supabase-js": "^2.95.3",
    "@turf/turf": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.9.0",
    "bcrypt": "^6.0.0",
    "file-saver": "^2.0.5",
    "firebase": "^11.6.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "knex": "^3.1.0",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lucide-react": "^0.552.0",
    "pg": "^8.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.4.0",
    "react-leaflet": "^4.2.1",
    "react-leaflet-draw": "^0.20.6",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.3.0",
    "uuid": "^11.1.0",
    "wellknown": "^0.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/file-saver": "^2.0.7",
    "@types/leaflet": "^1.9.19",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "globals": "^15.15.0",
    "jest": "^30.2.0",
    "postcss": "^8.5.6",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.24.1",
    "vite": "^5.2.0",
    "wait-on": "^9.0.3"
  }
}
