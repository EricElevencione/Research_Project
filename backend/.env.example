# ============================================================
# Incentive Distribution API - Environment Configuration
# ============================================================
# Copy this file to .env and update with your actual values

# ============================================================
# Server Configuration
# ============================================================
NODE_ENV=development
PORT=3001
INCENTIVE_PORT=3001

# ============================================================
# Database Configuration (PostgreSQL)
# ============================================================
# Required (Supabase): full connection string
# Example format:
# SUPABASE_DB_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_DB_URL=

# Optional generic connection string alias (used when SUPABASE_DB_URL is empty)
# DATABASE_URL=postgresql://username:password@host:5432/database_name

# Local DB_* fallback is intentionally disabled. This backend is Supabase-only.

# ============================================================
# Authentication
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT expiration (optional, default: 24h)
# JWT_EXPIRATION=24h

# ============================================================
# CORS Configuration
# ============================================================
# Comma-separated list of allowed origins (use * for all in development)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4200

# ============================================================
# Security (Production)
# ============================================================
# SSL is enabled automatically when connection strings are used.
# Override behavior if needed:
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# ============================================================
# Logging (Optional)
# ============================================================
# LOG_LEVEL=info
# LOG_FILE=./logs/app.log

# ============================================================
# Rate Limiting (Optional)
# ============================================================
# RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
# RATE_LIMIT_MAX_REQUESTS=100
